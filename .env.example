# Neon Postgres
NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Neon Auth (Better Auth)
# Provisioned via: npx neonctl@latest init   (then enable Auth on the branch)
NEON_AUTH_BASE_URL=https://<your-branch>.auth.neon.tech
NEON_AUTH_COOKIE_SECRET=replace-with-32+char-random-string
NEXT_PUBLIC_NEON_AUTH_URL=https://<your-branch>.auth.neon.tech

# Public app URL (used by Tauri to load the deployed web build, and by auth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter key is NOT stored here — it lives in the client (localStorage),
# entered per-user via the in-app Settings UI.
