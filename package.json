{
  "name": "work-tracker",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @work-tracker/web run dev",
    "build": "npm --workspace @work-tracker/web run build",
    "start": "npm --workspace @work-tracker/web run start",
    "tauri": "npm --workspace @work-tracker/desktop run tauri",
    "tauri:dev": "npm --workspace @work-tracker/desktop run dev",
    "tauri:build": "npm --workspace @work-tracker/desktop run build",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
