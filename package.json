{
  "name": "work-tracker",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @work-tracker/web dev",
    "build": "pnpm --filter @work-tracker/web build",
    "start": "pnpm --filter @work-tracker/web start",
    "tauri": "pnpm --filter @work-tracker/desktop tauri",
    "tauri:dev": "pnpm --filter @work-tracker/desktop tauri dev",
    "tauri:build": "pnpm --filter @work-tracker/desktop tauri build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
