{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "work-tracker",
  "version": "0.1.6",
  "identifier": "dev.devgenio.worktracker",
  "build": {
    "frontendDist": "https://work-tracker-six-gray.vercel.app",
    "devUrl": "https://work-tracker-six-gray.vercel.app"
  },
  "app": {
    "windows": [
      {
        "title": "work-tracker",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
