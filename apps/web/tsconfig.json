{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "noEmit": true,
    "allowJs": true,
    "paths": {
      "@/*": ["./*"],
      "@work-tracker/shared": ["../../packages/shared/src/index.ts"],
      "@work-tracker/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
